# Runtime config (contains credentials — use examples/ as template)
# Anchored to the repo root so the tracked examples/opencraig.yaml
# template isn't shadowed.
/opencraig.yaml
/myconfig.yaml

# Wizard checkpoint (in-progress setup state; auto-deleted on success)
*.yaml.wizard-state.json

# Benchmark (large result files with LLM outputs)
/benchmark_results/
/benchmark_cache/

# Logs
*.log

# Claude
/.claude

# Misc
test_localsystem.txt
*.pickle
/cloc-2.08.exe

# Smoke-test scratch (auto-minted token + sample request body)
.smoke-token
.smoke-body.json

# Personal dev workflow scripts — these hardcode the maintainer's
# remote dev box (user, host, SSH key path) and aren't meant to be
# shared. The topology they describe (local source → rclone →
# remote backend) is an internal preference; other contributors
# pick their own setup. Leave the files on disk (they aren't
# generated; the operator wrote them) but keep them out of git.
scripts/dev-remote.sh
scripts/dev-bootstrap-remote.sh
