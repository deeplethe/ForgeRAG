# ── LLM / Embedding API key (required for default config) ────────────────────
OPENAI_API_KEY=sk-...

# ── Config file path (optional, defaults to ./opencraig.yaml; legacy ./forgerag.yaml also accepted) ──
# OPENCRAIG_CONFIG=./opencraig.yaml

# ── Server bind (optional; legacy FORGERAG_HOST/FORGERAG_PORT also accepted) ──
# OPENCRAIG_HOST=0.0.0.0
# OPENCRAIG_PORT=8000

# ── PostgreSQL (if using postgres backend) ───────────────────────────────────
# POSTGRES_PASSWORD=your_password_here

# ── Neo4j (if using neo4j graph store) ───────────────────────────────────────
# NEO4J_PASSWORD=your_password_here

# ── S3 (if using s3 blob storage) ────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── Alibaba OSS (if using oss blob storage) ──────────────────────────────────
# OSS_ACCESS_KEY_ID=...
# OSS_ACCESS_KEY_SECRET=...
