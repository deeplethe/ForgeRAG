# ════════════════════════════════════════════════════════════════════════════
# OpenCraig — environment file for ``docker compose up``.
#
# Copy this to ``.env`` and fill in the placeholders before bringing the
# stack up. Everything in here is referenced by docker-compose.yml; the
# in-container config at /app/config.yaml reads these via ``*_env`` fields.
# ════════════════════════════════════════════════════════════════════════════

# ── Required: service passwords (generate strong random strings) ────────────
# Used by Postgres + Neo4j on first launch and read by opencraig at boot.
# Once data volumes exist, changing these forces you to also reset the
# corresponding service's auth — easier to pick once and keep.
POSTGRES_PASSWORD=change-me-to-something-random
NEO4J_PASSWORD=change-me-to-something-random

# ── Required: at least one LLM provider key ─────────────────────────────────
# OpenCraig uses litellm so any of these (or others) work. Set whichever
# matches the ``model`` strings in docker/config.yaml. The first-boot
# wizard surfaces a friendlier message when none are set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── Optional: host port mappings ────────────────────────────────────────────
# Override if the defaults clash with something else on this machine.
# OPENCRAIG_PORT=8000
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ── Optional: blob storage credentials when using s3 / oss backends ─────────
# Leave commented when using ``storage.mode: local`` (the default).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
